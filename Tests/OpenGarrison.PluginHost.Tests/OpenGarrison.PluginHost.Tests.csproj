<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <EnablePreviewFeatures>true</EnablePreviewFeatures>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.14.1" />
    <PackageReference Include="MonoGame.Framework.DesktopGL" Version="3.8.4.1" />
    <PackageReference Include="xunit" Version="2.9.3" />
    <PackageReference Include="xunit.runner.visualstudio" Version="3.1.2">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Client\OpenGarrison.Client.csproj" />
    <ProjectReference Include="..\..\Client.Shared\OpenGarrison.Client.Shared.csproj" />
    <ProjectReference Include="..\..\Server\OpenGarrison.Server.csproj" />
    <ProjectReference Include="..\..\Plugins\OpenGarrison.PluginHost.Abstractions\OpenGarrison.PluginHost.Abstractions.csproj" />
    <ProjectReference Include="..\..\Plugins\Client\OpenGarrison.Client.Plugins.Abstractions\OpenGarrison.Client.Plugins.Abstractions.csproj" />
    <ProjectReference Include="..\..\Plugins\Client\OpenGarrison.Client.Plugins.BubbleWheel\OpenGarrison.Client.Plugins.BubbleWheel.csproj" />
    <ProjectReference Include="..\..\Plugins\Server\OpenGarrison.Server.Plugins.Abstractions\OpenGarrison.Server.Plugins.Abstractions.csproj" />
  </ItemGroup>

  <Target Name="GenerateRuntimeAssetManifest"
          AfterTargets="Build"
          Condition="'$(DesignTimeBuild)' != 'true' and '$(OpenGarrisonPackageScriptOwnsContent)' != 'true'">
    <Exec Command="dotnet run --project &quot;$(MSBuildProjectDirectory)\..\..\Tools\BrowserAssetBuilder\OpenGarrison.Tools.BrowserAssetBuilder.csproj&quot; -- &quot;$(TargetDir)Content&quot; --manifest-only" />
  </Target>
</Project>
