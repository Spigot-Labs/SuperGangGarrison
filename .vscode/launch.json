{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Client (OG2)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "Build Client",
      "program": "${workspaceFolder}/Client/bin/Debug/net10.0/OG2.dll",
      "args": [],
      "cwd": "${workspaceFolder}/Client/bin/Debug/net10.0",
      "console": "internalConsole",
      "stopAtEntry": false
    },
    {
      "name": "Run Server",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "Build Server",
      "args": [],
      "cwd": "${workspaceFolder}/Server/bin/Debug/net10.0",
      "console": "integratedTerminal",
      "stopAtEntry": false
    },
    {
      "name": ".NET Core Attach",
      "type": "coreclr",
      "request": "attach"
    }
  ]
}
