{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Client",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/Client/OpenGarrison.Client.csproj",
        "-c",
        "Debug"
      ],
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Build and Run Client",
      "type": "process",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/Client/OpenGarrison.Client.csproj",
        "-c",
        "Debug"
      ],
      "problemMatcher": "$msCompile",
      "group": "build"
    },
    {
      "label": "Build Server",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/Server/OpenGarrison.Server.csproj",
        "-c",
        "Debug"
      ],
      "problemMatcher": "$msCompile",
      "group": "build"
    },
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/OpenGarrison.sln",
        "-c",
        "Debug",
        "-m:1"
      ],
      "problemMatcher": "$msCompile",
      "group": "build"
    }
  ]
}
