<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <AssemblyName>OG2</AssemblyName>
    <RollForward>Major</RollForward>
    <PublishReadyToRun>false</PublishReadyToRun>
    <TieredCompilation>false</TieredCompilation>
  </PropertyGroup>
  <PropertyGroup Condition="'$(OpenGarrisonClientAsLibrary)' == 'true'">
    <OutputType>Library</OutputType>
    <DefineConstants>$(DefineConstants);BROWSER_KNI</DefineConstants>
  </PropertyGroup>
  <PropertyGroup>
    <ApplicationManifest>Properties\app.manifest</ApplicationManifest>
    <ApplicationIcon>Properties\Icon.ico</ApplicationIcon>
    <PublishSingleFile>false</PublishSingleFile>
  </PropertyGroup>
  <ItemGroup>
    <None Remove="Properties\Icon.ico" />
    <None Remove="Properties\Icon.bmp" />
  </ItemGroup>
  <ItemGroup>
    <EmbeddedResource Include="Properties\Icon.ico">
      <LogicalName>Icon.ico</LogicalName>
    </EmbeddedResource>
    <EmbeddedResource Include="Properties\Icon.bmp">
      <LogicalName>Icon.bmp</LogicalName>
    </EmbeddedResource>
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="SixLabors.ImageSharp" Version="3.1.*" />
    <PackageReference Include="MoonSharp.Interpreter.netcore" Version="2.0.14" />
    <PackageReference Include="NVorbis" Version="0.10.5" />
  </ItemGroup>
  <ItemGroup Condition="'$(OpenGarrisonClientAsLibrary)' != 'true'">
    <PackageReference Include="DiscordRichPresence" Version="1.6.1.70" />
  </ItemGroup>
  <ItemGroup Condition="'$(OpenGarrisonClientAsLibrary)' == 'true'">
    <PackageReference Include="nkast.Kni.Platform.Blazor.GL" Version="4.2.9001.2" PrivateAssets="all" />
  </ItemGroup>
  <ItemGroup Condition="'$(OpenGarrisonClientAsLibrary)' != 'true'">
    <PackageReference Include="MonoGame.Framework.DesktopGL" Version="3.8.4.1" />
    <PackageReference Include="MonoGame.Content.Builder.Task" Version="3.8.4.1" PrivateAssets="all" />
  </ItemGroup>
  <ItemGroup>
    <None Include="..\Core\Content\**\*" Exclude="..\Core\Content\bin\**\*;..\Core\Content\obj\**\*;..\Core\Content\**\*.mgcb">
      <TargetPath>Content\%(RecursiveDir)%(Filename)%(Extension)</TargetPath>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Visible>false</Visible>
    </None>
    <None Include="practice-bot-names.txt">
      <TargetPath>config\practice-bot-names.txt</TargetPath>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Visible>false</Visible>
    </None>
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\BotAI\OpenGarrison.BotAI.csproj" />
    <ProjectReference Include="..\Client.Shared\OpenGarrison.Client.Shared.csproj" />
    <ProjectReference Include="..\Plugins\OpenGarrison.PluginHost.Abstractions\OpenGarrison.PluginHost.Abstractions.csproj" />
    <ProjectReference Include="..\Core\OpenGarrison.Core.csproj" />
    <ProjectReference Include="..\GameplayModding.Abstractions\OpenGarrison.GameplayModding.Abstractions.csproj" />
    <ProjectReference Include="..\Protocol\OpenGarrison.Protocol.csproj" />
  </ItemGroup>
  <ItemGroup Condition="'$(OpenGarrisonClientAsLibrary)' == 'true'">
    <ProjectReference Include="..\Plugins\Client\OpenGarrison.Client.Plugins.Abstractions\OpenGarrison.Client.Plugins.Abstractions.csproj">
      <AdditionalProperties>OpenGarrisonClientAsLibrary=true</AdditionalProperties>
    </ProjectReference>
  </ItemGroup>
  <ItemGroup Condition="'$(OpenGarrisonClientAsLibrary)' != 'true'">
    <ProjectReference Include="..\Plugins\Client\OpenGarrison.Client.Plugins.Abstractions\OpenGarrison.Client.Plugins.Abstractions.csproj" />
  </ItemGroup>
  <ItemGroup Condition="'$(OpenGarrisonClientAsLibrary)' == 'true'">
    <Compile Remove="obj\**\*.cs" />
    <Compile Remove="Program.cs" />
  </ItemGroup>

  <Target Name="GenerateDistributionContentAtlases"
          AfterTargets="Build"
          Condition="'$(OpenGarrisonClientAsLibrary)' != 'true' and Exists('$(TargetDir)Content')">
    <Exec Command="dotnet run --project &quot;$(MSBuildProjectDirectory)\..\Tools\BrowserAssetBuilder\OpenGarrison.Tools.BrowserAssetBuilder.csproj&quot; -- &quot;$(TargetDir)Content&quot;" />
  </Target>

  <Target Name="GeneratePublishedDistributionContentAtlases"
          AfterTargets="Publish"
          Condition="'$(OpenGarrisonClientAsLibrary)' != 'true' and Exists('$(PublishDir)Content')">
    <Exec Command="dotnet run --project &quot;$(MSBuildProjectDirectory)\..\Tools\BrowserAssetBuilder\OpenGarrison.Tools.BrowserAssetBuilder.csproj&quot; -- &quot;$(PublishDir)Content&quot;" />
  </Target>
</Project>
